# Copy to .env.local for local-only ECMA integration checks.
# Do not put real GHL tokens in tracked files or browser code.

ECMA_GHL_PRIVATE_INTEGRATION_TOKEN=
ECMA_GHL_LOCATION_ID=

# Optional: only needed if ECMA creates GHL opportunities or routes to a GHL calendar.
ECMA_GHL_PIPELINE_ID=
ECMA_GHL_PIPELINE_STAGE_ID=
ECMA_GHL_FORM_URL=
ECMA_GHL_BOOKING_URL=
